#!/bin/sh
# pre-commit — Automated enforcement (nguyên tắc 08 / principle 08)
#
# CHẠY ĐƯỢC NGAY với default Supabase + Next.js. Sửa 3 biến CẤU HÌNH bên dưới cho project khác.
# (Works out of the box for Supabase defaults. Edit the 3 CONFIG vars for other stacks.)
#
# Cài đặt KHUYẾN NGHỊ — versioned, mọi máy/agent đều bị enforce (xem 08 §hard-rules):
#   mkdir -p .githooks
#   cp templates/pre-commit.hook.template .githooks/pre-commit
#   git config core.hooksPath .githooks
#   git add .githooks   (commit cùng repo — máy clone mới chỉ cần chạy lại dòng git config)
#
# Cách cũ (1 máy — KHÔNG khuyến nghị, drift quay lại): cp vào .git/hooks/pre-commit
#
# Sau khi sửa config, verify: sh .githooks/pre-commit --self-test

# ── CẤU HÌNH / CONFIG — sửa theo project ──────────────────────────────
MIGRATIONS_PATTERN='supabase/migrations/.*\.sql$'         # prisma/migrations/.* | db/migrate/.* ...
DB_DOC_PATTERN='docs/.*(database|db|schema).*\.md$'       # doc nào được tính là "doc database"
CLAUDE_MD_CHAR_BUDGET=24000                               # ~6K tokens (EN ~4 chars/token; VN-heavy có thể hạ 20000)
# Sample paths cho --self-test — đổi CÙNG LÚC với 2 pattern trên:
SELF_TEST_MIGRATION_SAMPLE='supabase/migrations/0001_sample.sql'
SELF_TEST_DOC_SAMPLE='docs/app-map/03-database-and-automation.md'

if [ "$1" = "--self-test" ]; then
  echo "ok: hook parse duoc."
  RC=0
  if echo "$SELF_TEST_MIGRATION_SAMPLE" | grep -qE "$MIGRATIONS_PATTERN" 2>/dev/null; then
    echo "PASS: MIGRATIONS_PATTERN khop '$SELF_TEST_MIGRATION_SAMPLE'"
  else
    echo "FAIL: MIGRATIONS_PATTERN KHONG khop sample (pattern sai hoac ERE invalid) -> check 1 se silent no-op!"
    RC=1
  fi
  if echo "$SELF_TEST_DOC_SAMPLE" | grep -qiE "$DB_DOC_PATTERN" 2>/dev/null; then
    echo "PASS: DB_DOC_PATTERN khop '$SELF_TEST_DOC_SAMPLE'"
  else
    echo "FAIL: DB_DOC_PATTERN KHONG khop sample -> moi migration commit se bi block oan!"
    RC=1
  fi
  echo "  BUDGET = $CLAUDE_MD_CHAR_BUDGET chars"
  exit $RC
fi

CHANGED=$(git diff --cached --name-only)
FAIL=0

# ── 1. Migration đổi → doc database phải đổi cùng commit ──────────────
if echo "$CHANGED" | grep -qE "$MIGRATIONS_PATTERN"; then
  if ! echo "$CHANGED" | grep -qiE "$DB_DOC_PATTERN"; then
    echo "BLOCK: migration thay doi nhung doc database khong update."
    echo "  -> Update docs/app-map/*database*.md (hoac regenerate _generated/schema.md) roi commit lai."
    FAIL=1
  fi
fi

# ── 2. Root CLAUDE.md token budget ─────────────────────────────────────
# Ratchet: chỉ check khi CLAUDE.md nằm trong commit — vi phạm tồn đọng được "ân hạn"
# tới lần sửa kế tiếp (tránh hook fail mọi commit khi retrofit vào repo cũ).
# Đo BLOB ĐÃ STAGE (git show :CLAUDE.md), không đo working tree — tránh block/pass oan
# khi worktree khác staged. Guard cat-file: file đang bị staged-delete thì bỏ qua.
if echo "$CHANGED" | grep -qx 'CLAUDE.md'; then
  if git cat-file -e :CLAUDE.md 2>/dev/null; then
    SIZE=$(git show :CLAUDE.md | wc -c | tr -d ' ')
    if [ "$SIZE" -gt "$CLAUDE_MD_CHAR_BUDGET" ]; then
      echo "BLOCK: CLAUDE.md (staged) ${SIZE} chars > budget ${CLAUDE_MD_CHAR_BUDGET} (~6K tokens)."
      echo "  -> Tach bang/chi tiet ra docs/app-map/, root chi giu rule + pointer (nguyen tac 01 \"root diet\")."
      FAIL=1
    fi
  fi
fi

# ── 3. Schema dùng chung đổi → contract phải đổi cùng commit (nguyên tắc 10) ──
# Khai báo từng cặp schema→contract. Bỏ comment + sửa pattern cho mỗi schema chung.
check_contract() {
  if echo "$CHANGED" | grep -qE "$1"; then
    if ! echo "$CHANGED" | grep -qE "$2"; then
      echo "BLOCK: schema dung chung ($1) doi nhung contract ($2) khong update."
      echo "  -> Update contract (bump version neu breaking) roi commit lai."
      FAIL=1
    fi
  fi
}
# Ví dụ / example:
# check_contract 'modules/plan_writer\.py' 'docs/contracts/plan-json\.contract\.md'

# ── 4. WARN (không chặn): app-map file thiếu chuẩn ────────────────────
for f in $(echo "$CHANGED" | grep -E 'docs/app-map/.*\.md$' | grep -v '_generated/' || true); do
  [ -f "$f" ] || continue
  if ! head -5 "$f" | grep -qiE 'load (khi|when)'; then
    echo "WARN: $f thieu dong 'Load khi/Load when' o dau file (nguyen tac 02)."
  fi
done

[ "$FAIL" -eq 1 ] && exit 1
exit 0
