#!/bin/sh
# doc-health-report — tầng 3 của nguyên tắc 08 (MEASURE). Chạy tay hoặc cron tuần.
# Output: text report ra stdout — pipe sang Telegram/Slack tuỳ hệ thống của bạn.
#
# Usage: sh doc-health-report.sh [budget_chars]      (chạy tại root repo; default 24000)
#        CLAUDE_MD_CHAR_BUDGET=20000 sh doc-health-report.sh
#        sh doc-health-report.sh --ci                 (CI mode: exit 1 khi drift < ngưỡng
#                                                      hoặc có broken cross-ref → fail PR)
#
# Wiring cron tuần — chọn 1:
#   Windows (scheduled task khởi động ở System32 → PHẢI cd vào repo trước):
#     schtasks /create /tn "doc-health" /sc weekly /d MON /st 08:00 ^
#       /tr "\"C:\Program Files\Git\bin\sh.exe\" -c \"cd /c/path/repo && sh scripts/doc-health-report.sh\""
#   GitHub Actions (.github/workflows/doc-health.yml — fetch-depth: 0 bắt buộc cho timestamp):
#     on: { schedule: [ { cron: "0 1 * * 1" } ], pull_request: {} }
#     jobs: { report: { runs-on: ubuntu-latest, steps: [
#       { uses: actions/checkout@v4, with: { fetch-depth: 0 } },
#       { run: "sh scripts/doc-health-report.sh --ci" } ] } }

# ── CONFIG — sửa theo layout repo (default: Next.js + Supabase) ────────
SRC_PATTERN='^src/'                    # Python agent repo: '^(modules|agents|lib|tools)/'
DOCS_PATTERN='^docs/'
MIGRATIONS_DIR='supabase/migrations'   # prisma/migrations | db/migrate ...
DRIFT_MIN_PCT=95                       # --ci fail nếu drift % dưới ngưỡng này

CI_MODE=0
if [ "$1" = "--ci" ]; then CI_MODE=1; shift; fi
BUDGET=${1:-${CLAUDE_MD_CHAR_BUDGET:-24000}}
CI_FAIL=0

echo "=== Doc health report — $(date +%Y-%m-%d) ==="

# ── 1. Drift %: trong 20 commit gần nhất, % commit sửa code có kèm docs ──
TOTAL=0; WITHDOC=0
for c in $(git log -20 --format=%H); do
  FILES=$(git show --name-only --format= "$c")
  if echo "$FILES" | grep -qE "$SRC_PATTERN"; then
    TOTAL=$((TOTAL+1))
    if echo "$FILES" | grep -qE "$DOCS_PATTERN"; then WITHDOC=$((WITHDOC+1)); fi
  fi
done
if [ "$TOTAL" -gt 0 ]; then
  PCT=$((WITHDOC * 100 / TOTAL))
  echo "Drift: $WITHDOC/$TOTAL ($PCT%) commit sua code co kem docs (muc tieu >= $DRIFT_MIN_PCT%)"
  [ "$PCT" -lt "$DRIFT_MIN_PCT" ] && CI_FAIL=1
else
  echo "Drift: khong co commit sua code (pattern: $SRC_PATTERN) trong 20 commit gan nhat"
fi

# ── 2. App-map stale: file chưa sửa > 30 ngày (bỏ _generated — đã có check 3b) ──
echo "--- App-map chua sua > 30 ngay ---"
NOW=$(date +%s)
git ls-files 'docs/app-map/*.md' 'docs/app-map/**/*.md' 2>/dev/null | grep -v '_generated/' | while read -r f; do
  TS=$(git log -1 --format=%ct -- "$f" 2>/dev/null)
  [ -n "$TS" ] || continue
  AGE=$(( (NOW - TS) / 86400 ))
  [ "$AGE" -gt 30 ] && echo "  $f — ${AGE}d"
done

# ── 3. Token budget trend ──────────────────────────────────────────────
if [ -f CLAUDE.md ]; then
  echo "CLAUDE.md: $(wc -c < CLAUDE.md | tr -d ' ') chars (budget $BUDGET ~ 6K tokens)"
fi

# ── 3b. _generated/ cũ hơn source of truth (nguyên tắc 09) ─────────────
if [ -d docs/app-map/_generated ] && [ -d "$MIGRATIONS_DIR" ]; then
  GEN_TS=$(git log -1 --format=%ct -- docs/app-map/_generated/ 2>/dev/null)
  MIG_TS=$(git log -1 --format=%ct -- "$MIGRATIONS_DIR/" 2>/dev/null)
  if [ -n "$GEN_TS" ] && [ -n "$MIG_TS" ] && [ "$MIG_TS" -gt "$GEN_TS" ]; then
    echo "STALE: migrations moi hon _generated/ -> chay lai generator (schema doc dang cu)"
    CI_FAIL=1
  fi
fi

# ── 3c. Lint app-map: thiếu "Load khi" / thiếu last-updated ────────────
echo "--- App-map lint ---"
git ls-files 'docs/app-map/*.md' 2>/dev/null | grep -v '_generated/' | while read -r f; do
  head -5 "$f" | grep -qiE 'load (khi|when)' || echo "  $f: thieu 'Load khi'"
  tail -5 "$f" | grep -qiE 'last.updated|cap nhat' || echo "  $f: thieu last-updated"
done

# ── 4. Broken cross-ref trong app-map (link relative tới file không tồn tại) ──
# Gom output ra biến vì while-trong-pipe là subshell — set CI_FAIL ở đó sẽ mất.
echo "--- Broken cross-ref ---"
BROKEN=$(git ls-files 'docs/app-map/*.md' 'docs/app-map/**/*.md' 2>/dev/null | sort -u | while read -r f; do
  DIR=$(dirname "$f")
  grep -oE '\]\(([^)#]+\.md)' "$f" | sed 's/](//' | while read -r link; do
    case "$link" in http*|/*) continue ;; esac
    [ -f "$DIR/$link" ] || echo "  $f -> $link (khong ton tai)"
  done
done)
if [ -n "$BROKEN" ]; then
  echo "$BROKEN"
  CI_FAIL=1
fi

echo "=== Het report ==="
if [ "$CI_MODE" -eq 1 ] && [ "$CI_FAIL" -eq 1 ]; then
  echo "CI: FAIL — drift duoi nguong / _generated stale / broken cross-ref (xem tren)"
  exit 1
fi
exit 0
